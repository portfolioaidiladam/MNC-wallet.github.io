# ---------------------------------------------------------------------------
# MNC Wallet API — environment variables
# Copy this file to `.env` and adjust sesuai environment lokal kamu.
# JANGAN commit file `.env` yang berisi secret asli.
# ---------------------------------------------------------------------------

# App
APP_ENV=development
HTTP_PORT=8000
TZ=Asia/Jakarta

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mncwallet
POSTGRES_PASSWORD=mncwallet
POSTGRES_DB=mncwallet
POSTGRES_SSLMODE=disable

# Redis (Asynq broker)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168

# Asynq worker
ASYNQ_CONCURRENCY=10
